{
  "routes": [
    {
      "route": "/.github/*",
      "statusCode": 404
    },
    {
      "route": "/infra/*",
      "statusCode": 404
    },
    {
      "route": "/render/*",
      "statusCode": 404
    }
  ],
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
